---
type SelectOption = {
  value: string;
  label: string;
  disabled?: boolean;
};

type Props = {
  class?: string;
  name?: string;
  required?: boolean;
  placeholder?: string;
  options?: SelectOption[];
};

const {
  class: _class = "",
  name = "",
  required = false,
  placeholder = "",
  options = [],
} = Astro.props as Props;
---

<div>
  <select
    class:list={[
      "w-full px-6 py-3 bg-gray-200 text-gray-700 data-error:border-red-500 focus:data-error:border-red-500 focus:outline-none focus:ring-2 focus:ring-primary transition-border duration-200 rounded-full",
      _class,
    ]}
    name={name}
    required={required}
  >
    {placeholder && (
      <option value="" disabled selected>
        {placeholder}
      </option>
    )}

    {options.map((option) => (
      <option value={option.value} disabled={option.disabled}>
        {option.label}
      </option>
    ))}
  </select>
</div>
