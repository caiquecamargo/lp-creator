---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  images: { src: ImageMetadata; alt: string }[];
}

const { images } = Astro.props;
---

<image-gallery class="block">
  <div class="relative max-w-7xl mx-auto px-4">
    <!-- Gallery Container -->
    <div class="overflow-hidden">
      <div
        class="gallery-track flex transition-transform duration-500 ease-in-out"
      >
        {
          images.map((image) => (
            <div class="gallery-item min-w-full md:min-w-[33.333%] px-2">
              <Image
                src={image.src}
                alt={image.alt}
                class="w-full h-100 object-cover rounded-lg shadow-lg"
              />
            </div>
          ))
        }
      </div>
    </div>

    <!-- Navigation Arrows -->
    <button
      class="prev-btn absolute -left-8 top-1/2 -translate-y-1/2 hover:bg-white/20 p-3 rounded-full shadow-lg transition-all"
      aria-label="Previous images"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"></path>
      </svg>
    </button>

    <button
      class="next-btn absolute -right-8 top-1/2 -translate-y-1/2 hover:bg-white/20 p-3 rounded-full shadow-lg transition-all"
      aria-label="Next images"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"></path>
      </svg>
    </button>
  </div>
</image-gallery>

<script>
  class ImageGallery extends HTMLElement {
    private currentPage = 0;
    private itemsPerPage = 3;
    private track: HTMLElement | null = null;
    private prevBtn: HTMLButtonElement | null = null;
    private nextBtn: HTMLButtonElement | null = null;
    private totalItems = 0;
    private totalPages = 0;

    connectedCallback() {
      this.track = this.querySelector(".gallery-track");
      this.prevBtn = this.querySelector(".prev-btn");
      this.nextBtn = this.querySelector(".next-btn");

      if (!this.track) return;

      this.totalItems = this.track.children.length;
      this.updateItemsPerPage();
      this.totalPages = Math.ceil(this.totalItems / this.itemsPerPage);

      this.updateGallery();

      this.prevBtn?.addEventListener("click", () => this.prev());
      this.nextBtn?.addEventListener("click", () => this.next());

      window.addEventListener("resize", () => {
        this.updateItemsPerPage();
        this.totalPages = Math.ceil(this.totalItems / this.itemsPerPage);
        this.currentPage = Math.min(this.currentPage, this.totalPages - 1);
        this.updateGallery();
      });
    }

    private updateItemsPerPage() {
      this.itemsPerPage = window.innerWidth < 768 ? 1 : 3;
    }

    private updateGallery() {
      if (!this.track) return;

      const offset = -this.currentPage * 100;
      this.track.style.transform = `translateX(${offset}%)`;

      // Update button states
      if (this.prevBtn) {
        this.prevBtn.disabled = this.currentPage === 0;
        this.prevBtn.style.opacity = this.currentPage === 0 ? "0.5" : "1";
      }
      if (this.nextBtn) {
        this.nextBtn.disabled = this.currentPage === this.totalPages - 1;
        this.nextBtn.style.opacity =
          this.currentPage === this.totalPages - 1 ? "0.5" : "1";
      }
    }

    private prev() {
      if (this.currentPage > 0) {
        this.currentPage--;
        this.updateGallery();
      }
    }

    private next() {
      if (this.currentPage < this.totalPages - 1) {
        this.currentPage++;
        this.updateGallery();
      }
    }
  }

  customElements.define("image-gallery", ImageGallery);
</script>
