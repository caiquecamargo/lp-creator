---
type Props = {
  class?: string;
  type?: astroHTML.JSX.HTMLInputTypeAttribute | "textarea";
  placeholder?: string;
  name?: string;
  required?: boolean;
};

const {
  class: _class = "",
  type = "text",
  placeholder = "",
  name = "",
  required = false,
} = Astro.props as Props;

const isTextarea = type === "textarea";
const Element = isTextarea ? "textarea" : "input";
---

<div>
  <Element
    class:list={[
      "w-full px-6 py-3 bg-gray-200 text-gray-700 data-error:border-red-500 focus:data-error:border-red-500 focus:outline-none focus:ring-2 focus:ring-primary transition-border duration-200",
      isTextarea ? "rounded-3xl" : "rounded-full",
      _class,
    ]}
    name={name}
    type={isTextarea ? undefined : type}
    rows={10}
    required={required}
    placeholder={placeholder}
  />
</div>
