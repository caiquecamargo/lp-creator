---
import Layout from "@/layouts/Layout.astro";
import markBlink from "@/assets/images/fundo-mark-tl.webp";
import { Image } from "astro:assets";
import IconParkSolidCorrect from '~icons/icon-park-solid/correct'
import Input from "@/components/input.astro";
import Select from "@/components/select.astro";
import ButtonPrimary from "@/components/button-primary.astro";
import { throwIfNotExists } from "@/utils/collection";
import { getEntry } from "astro:content";

export const prerender = true;

const positions = [
  "top-0 md:-top-[10%] -left-[5%] w-[100px] md:w-[250px]",
  "-top-[5%] right-0 w-[100px] md:w-[160px]",
  "top-[50%] right-0 md:-right-[5%] w-[250px] md:w-[450px]",
  "bottom-0 left--2% w-[100px] md:w-[200px]",
]

const config = throwIfNotExists(await getEntry("page", "page-config"));
---

<Layout class="bg-linear-to-r from-primary to-primary-dark relative overflow-y-auto">

  {
    positions.map((_class) => (
      <Image
        src={markBlink}
        alt="mark blink"
        class:list={["h-auto absolute", _class]}
      />
    ))
  }

	<header class="relative flex justify-between px-8 py-8">
	  <div class="flex-1" />
	  <Image
      src={config.data.header.logo}
      alt="Logo"
      class="w-auto h-10 md:h-20 flex-0"
    />
    <div class="flex-1 flex justify-end">
      <Image
        src={config.data.header.marker}
        alt="Logo Right"
        class="w-auto h-12 md:h-20"
      />
    </div>
	</header>

	<main>
  	<article>
      <section class="w-full max-w-380 mx-auto relative pb-16 px-1">
        <Image
          src={config.data.header.banner}
          alt="Banner"
          class="w-full h-auto"
        />
      </section>
  	</article>

    <article class="py-16 bg-secondary">
      <section class="w-full max-w-7xl mx-auto relative px-2">
        <section class="flex flex-col md:flex-row items-center justify-around">
          {
            config.data.chars.map((text) => (
              <div class="flex items-center gap-4 mb-4">
                <IconParkSolidCorrect class="size-6" />
                <span class="text-lg md:text-2xl text-white font-bold">{text.label}</span>
              </div>
            ))
          }
        </section>

        <section class="grid md:grid-cols-[15%_1fr] gap-8 mt-8">
          <div class="hidden md:block">
            <Image
              src={config.data.form.bannerForm}
              alt="Banner Vertical"
              class="w-full h-auto"
            />
          </div>
          <div class="space-y-4">
            <h3 class="font-extrabold text-xl md:text-3xl uppercase text-primary-dark text-center pb-4">{config.data.form.formTitle}</h3>

            <contact-form data-config={JSON.stringify(config.data.form)}>
              <form id="contact-form" class="space-y-6">
                <input type="hidden" name="input-bot" value="" />
                {
                  config.data.form.formFields.map(field => (
                    <>
                      {field.type === "text" && (
                        <Input name={field.name} placeholder={field.label} required={field.required} />
                      )}
                      {field.type === "select" && (
                        <Select name={field.name} placeholder={field.label} options={field.options} />
                      )}
                    </>
                  ))
                }
                <div id="form-status" class="hidden text-sm font-medium"></div>

                <div class="pt-2">
                  <ButtonPrimary type="submit" class="mt-8 block mx-auto absolute -bottom-22 left-[calc(50%-117px)] z-10">{config.data.form.button}</ButtonPrimary>
                </div>
              </form>
            </contact-form>
          </div>
        </section>

      </section>
    </article>
	</main>

	<footer class="relative flex flex-col gap-y-8 md:flex-row justify-around items-center py-16">
    <div>
  	  <div class="flex items-center gap-4">
  			<Image
          src={config.data.footer.logo}
          alt="Logo"
          class="w-auto h-16"
        />
     </div>
		</div>

		<div class="text-2xl text-white text-center">
		  { config.data.footer.phones.map(phone => (
        <p><b>{phone.label}</b></p>
      ))}
		</div>

		<div class="text-white">
      <p class="text-secondary mb-2 font-bold">#VemSerInterone</p>

      {
          config.data.footer.addresses.map(line => (
            <p>{line.label}</p>
          ))
      }
		</div>
	</footer>
</Layout>

<script>
  import { FORM_APIKEY, FORM_URL } from 'astro:env/client';

  type FormEntry = { name: string };

  class ContactForm extends HTMLElement {
    connectedCallback() {
      const form = this.querySelector<HTMLFormElement>("#contact-form");
      const statusEl = this.querySelector<HTMLDivElement>("#form-status");
      const config = JSON.parse(this.getAttribute("data-config") || "{}");

      if (!form || !statusEl) return;

      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        const submitBtn = form.querySelector<HTMLButtonElement>(
          'button[type="submit"]',
        );
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = "Enviando...";
        }

        statusEl.className = "hidden";

        const formData = new FormData(form);

        try {
          if (formData.get("input-bot")) {
            throw new Error("Bot detected");
          }

          const input = {
            form: "contato",
            params: config.formFields.reduce((acc: Record<string, FormDataEntryValue | null>, field: FormEntry) => {
              acc[field.name] = formData.get(field.name);
              return acc;
            }, {}),
          };

          const response = await fetch(FORM_URL, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'x-api-key': FORM_APIKEY,
            },
            body: JSON.stringify(input),
          });

          if (!response.ok) {
            statusEl.textContent =
                  "Erro ao enviar mensagem. Verifique se todos os campos estão preenchidos e corretamente.";
            statusEl.className = "text-sm font-medium text-red-500";
            return;
          }

          setTimeout(() => {
            statusEl.textContent = config.formSuccessMessage || "Mensagem enviada com sucesso!";
            statusEl.className = "text-sm font-medium text-green-500";
          }, 500);
        } catch {
          statusEl.textContent =
            "Erro ao enviar mensagem. Tente novamente mais tarde.";
          statusEl.className = "text-sm font-medium text-red-500";
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = "Entrar em contato";
          }
        }
      });
    }
  }

  customElements.define("contact-form", ContactForm);
</script>
