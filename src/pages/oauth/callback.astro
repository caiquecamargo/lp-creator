---
import { clientId, githubUrl, githubApiKey } from './_config';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OAuth Callback</title>
</head>
<body>
  <p>Authenticating...</p>
  <script define:vars={{ clientId, githubUrl, githubApiKey }}>

    (async function() {
      const urlParams = new URLSearchParams(window.location.search);
      const code = urlParams.get('code');

      console.log({
        code,
        clientId,
        githubUrl,
        githubApiKey,
      })

      if (!code) {
        document.body.innerHTML = '<h1>Error</h1><p>No code provided</p>';
        return;
      }

      const data = {
        code,
      };

      try {
        const response = await fetch(githubUrl, {
          method: 'POST',
          headers: {
            'Accept': 'application/json',
            'Content-Type': 'application/json',
            'x-api-key': githubApiKey,
          },
          body: JSON.stringify(data),
        });

        if (!response.ok) {
          console.log('Token exchange failed:', response.status, await response.text());
          throw new Error(`HTTP error! status: ${response.status}`);
        }

        // The response responds with an HTML with the script to communicate with github
        const text = await response.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(text, 'text/html');
        const script = doc.querySelector('script');

        if (script) {
          eval(script.textContent);
        } else {
          console.error('No script found in the response');
          throw new Error('No script found in the response');
        }
      }
      catch (err) {
        console.error('OAuth callback error:', err);
        window.location.href = '/?error=oauth_failed';
      }
    })();
  </script>
</body>
</html>
